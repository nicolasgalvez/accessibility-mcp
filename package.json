{
  "name": "accessibility-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing WAI-ARIA APG patterns, requirements, and example source from w3c/aria-practices",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "accessibility-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "ingest": "tsx scripts/ingest.ts",
    "rag:index": "tsx scripts/index-rag.ts",
    "ollama:smoke": "tsx scripts/ollama-smoke.ts",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "keywords": [
    "mcp",
    "a11y",
    "wai-aria",
    "apg",
    "accessibility"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.1.34",
    "@langchain/ollama": "^1.2.6",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "fastmcp": "^3.34.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
