# Ollama HTTP API (no trailing slash). Default port is 11434.
OLLAMA_BASE_URL=http://192.168.1.69:11434

# Chat completions (LangChain ChatOllama)
OLLAMA_CHAT_MODEL=llama3.2

# Embeddings for RAG / similarity (LangChain OllamaEmbeddings)
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# Set to 1/true to skip /api/pull on MCP startup (models must already exist)
# OLLAMA_SKIP_PULL=0

# Optional: override vendored APG data directory
# APG_MCP_DATA_DIR=/absolute/path/to/data
