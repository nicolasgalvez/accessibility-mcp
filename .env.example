# Ollama HTTP API (no trailing slash). Default port is 11434.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional: run chat and embeddings on different hosts (e.g. GPU box for chat, CPU/embed server).
# When unset, both use OLLAMA_BASE_URL.
# OLLAMA_CHAT_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBEDDING_BASE_URL=http://127.0.0.1:11434

# Chat (LangChain ChatOllama). Default: llama3.1:8b — stronger than 3B-class models.
# Alternatives: llama3.3, qwen2.5:7b, mistral, etc. (see ollama.com/library)
OLLAMA_CHAT_MODEL=llama3.1:8b

# Embeddings (RAG). Default: nomic-embed-text — strong for retrieval, 8k context (Ollama registry).
# After changing this, run: npm run rag:index
# Alternatives: mxbai-embed-large, bge-m3, embeddinggemma
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Set to 1 to skip Ollama model checks/pulls entirely (runs in background after MCP connects).
# OLLAMA_SKIP_PULL=1
# Set to 1 for extra Ollama status on stderr (default: quiet).
# OLLAMA_VERBOSE=1

# Optional: override vendored APG data directory
# APG_MCP_DATA_DIR=
